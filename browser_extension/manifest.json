{
  "manifest_version": 3,
  "name": "Unclaimed Property JSON Collector",
  "version": "0.2.0",
  "description": "Captures unclaimed property JSON responses after manual searches.",

  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "downloads",
    "storage"
  ],

"host_permissions": [
  "<all_urls>"
],
"content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }
],
"web_accessible_resources": [
  {
    "resources": ["injected.js"],
    "matches": ["<all_urls>"]
  }
]
}